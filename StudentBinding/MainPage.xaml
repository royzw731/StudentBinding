<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StudentBinding.MainPage">
    

    <VerticalStackLayout Padding="30"
                         Spacing="20"
                         VerticalOptions="Center"
                        >

        <Image Source="{Binding ShownStudent.Image}"
               HeightRequest="300"
               WidthRequest="300"
               Aspect="AspectFill"/>

        <Label Text="{Binding ShownStudent.Name}"
               FontSize="40"
               TextColor="Indigo"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Label Text="{Binding ShownStudent.Age}"
               FontSize="40"
               TextColor="Indigo"
               FontAttributes="Bold"
              
               HorizontalOptions="Center"/>
        <Label Text="{Binding ShownStudent.Gender}"
                           FontSize="40"
                           TextColor="Indigo"
               FontAttributes="Bold"
                           HorizontalOptions="Center"/>

        <DatePicker Date="{Binding ShownStudent.BirthDate}"
                    HorizontalOptions="Center"/>

        <Button Text="החלף סטודנט"
                HorizontalOptions="Center"
                BackgroundColor="Indigo"
                Clicked="Button_Clicked"/>

    </VerticalStackLayout>

</ContentPage>